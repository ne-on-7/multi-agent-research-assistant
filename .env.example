ANTHROPIC_API_KEY=sk-ant-xxxxx
GOOGLE_API_KEY=AIzaxxxxx
LLM_PRIMARY=claude
LLM_FALLBACK=gemini
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Web search — optional. When set, uses Tavily (ranked, LLM-ready results).
# Falls back to DuckDuckGo automatically if left blank. Get a key at https://tavily.com
TAVILY_API_KEY=

# Observability — optional. Tracing is enabled only when BOTH keys are set.
# Free cloud tier at https://cloud.langfuse.com
# Set LANGFUSE_BASE_URL to match your region: US -> https://us.cloud.langfuse.com,
# EU -> https://cloud.langfuse.com. (LANGFUSE_HOST is also still accepted.)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
